# Copy this file to .env.local and fill in your values

# Razorpay Keys - Get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# This is also used on the frontend (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# Razorpay Webhook Secret - Get from Razorpay Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# Hostinger SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@onegrasp.com
SMTP_PASS=YOUR_EMAIL_PASSWORD_HERE
